        <!-- ═══ COLUMN HEADERS ═══ -->

        <mxCell id="p7-h1" value="🔴  DO FIRST  |  Days 1–30&#xa;Fix gaps — stop bleeding leads + money" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fontColor=#ffffff;fillColor=#c0392b;strokeColor=#922b21;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
