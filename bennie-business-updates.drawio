        <mxCell id="p7-d2-5" value="&lt;b&gt;5. Track leads in Notion CRM (free)&lt;/b&gt;&lt;br/&gt;Columns: Name | Source | Status | $ | Next step&lt;br/&gt;&lt;font style='font-size:7px;' color='#e67e22'&gt;⏱️ 30 min | Claude builds the template&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#fef9e7;strokeColor=#e67e22;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
