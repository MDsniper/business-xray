        <!-- Title -->
        <mxCell id="p7-title" value="90-DAY ROADMAP → $40K MRR" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="40" y="12" width="1400" height="34" as="geometry"/>
