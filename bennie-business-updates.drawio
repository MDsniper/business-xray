        <mxCell id="p7-d3-3" value="&lt;b&gt;3. Group coaching format ($297/mo)&lt;/b&gt;&lt;br/&gt;AI for Biz Owners cohort — 20 people = $5,940/mo&lt;br/&gt;&lt;font style='font-size:7px;' color='#1e8449'&gt;This is the leverage play&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#eafaf1;strokeColor=#1e8449;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
