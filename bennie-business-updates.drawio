        </mxCell>
        <mxCell id="p7-h2" value="🟠  DO NEXT  |  Days 31–60&#xa;Build traffic + close first real revenue" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fontColor=#ffffff;fillColor=#e67e22;strokeColor=#ca6f1e;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="510" y="52" width="455" height="54" as="geometry"/>
        </mxCell>
        <mxCell id="p7-h3" value="🟢  DO LATER  |  Days 61–90&#xa;Scale: packages, wife's HR, recurring revenue" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fontColor=#ffffff;fillColor=#1e8449;strokeColor=#196f3d;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="980" y="52" width="455" height="54" as="geometry"/>
        </mxCell>

        <!-- ═══ DO FIRST ITEMS (x=40) ═══ -->

        <mxCell id="p7-d1-1" value="&lt;b&gt;1. Add Calendly link to website&lt;/b&gt;&lt;br/&gt;Free consult booking in nav + every page CTA&lt;br/&gt;&lt;font style='font-size:7px;' color='#c0392b'&gt;⏱️ 20 min | Calendly free plan&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#fdedec;strokeColor=#c0392b;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="116" width="455" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p7-d1-2" value="&lt;b&gt;2. Set up Stripe to accept payments&lt;/b&gt;&lt;br/&gt;Create payment links for each service — send in email&lt;br/&gt;&lt;font style='font-size:7px;' color='#c0392b'&gt;⏱️ 30 min | Stripe free to start&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#fdedec;strokeColor=#c0392b;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="196" width="455" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p7-d1-3" value="&lt;b&gt;3. Add email opt-in to website&lt;/b&gt;&lt;br/&gt;Lead magnet: &quot;5 AI tools every small biz needs&quot; PDF&lt;br/&gt;&lt;font style='font-size:7px;' color='#c0392b'&gt;⏱️ 2 hrs | MailerLite free tier&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#fdedec;strokeColor=#c0392b;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="276" width="455" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p7-d1-4" value="&lt;b&gt;4. Launch YouTube channel + upload 1st video&lt;/b&gt;&lt;br/&gt;Topic: &quot;I set up AI for a small business in 1 hour&quot;&lt;br/&gt;&lt;font style='font-size:7px;' color='#c0392b'&gt;⏱️ 1 day | Claude for script&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#fdedec;strokeColor=#c0392b;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="356" width="455" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p7-d1-5" value="&lt;b&gt;5. List your 3 services with clear prices&lt;/b&gt;&lt;br/&gt;AI Coaching ($150/hr), Website ($400), Agent Setup ($300)&lt;br/&gt;&lt;font style='font-size:7px;' color='#c0392b'&gt;⏱️ 1 hr | update benniewilliams.com&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#fdedec;strokeColor=#c0392b;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="436" width="455" height="70" as="geometry"/>
        </mxCell>

        <!-- ═══ DO NEXT ITEMS (x=510) ═══ -->

        <mxCell id="p7-d2-1" value="&lt;b&gt;1. Publish 1 YouTube video/week (4 total)&lt;/b&gt;&lt;br/&gt;Topics: AI tools for restaurants, law firms, HR, retail&lt;br/&gt;&lt;font style='font-size:7px;' color='#e67e22'&gt;⏱️ 4-6 hrs/video | Claude + CapCut&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#fef9e7;strokeColor=#e67e22;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="510" y="116" width="455" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p7-d2-2" value="&lt;b&gt;2. Close 3 PAYING clients (not family)&lt;/b&gt;&lt;br/&gt;DM 10 people from your network about AI coaching&lt;br/&gt;&lt;font style='font-size:7px;' color='#e67e22'&gt;Target: 3 × $300 = $900 MRR&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#fef9e7;strokeColor=#e67e22;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="510" y="196" width="455" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p7-d2-3" value="&lt;b&gt;3. Collect 3 written testimonials&lt;/b&gt;&lt;br/&gt;Ask every client — add to website + YouTube description&lt;br/&gt;&lt;font style='font-size:7px;' color='#e67e22'&gt;⏱️ 10 min each | Claude drafts the ask email&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#fef9e7;strokeColor=#e67e22;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="510" y="276" width="455" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p7-d2-4" value="&lt;b&gt;4. Build 3-email welcome sequence&lt;/b&gt;&lt;br/&gt;Email 1: welcome + free resource | E2: case study | E3: CTA&lt;br/&gt;&lt;font style='font-size:7px;' color='#e67e22'&gt;⏱️ 2 hrs | Claude writes all 3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#fef9e7;strokeColor=#e67e22;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
