        <!-- ═══ PATH TO $40K MRR (bottom section) ═══ -->

        <mxCell id="p7-path-bg" value="" style="rounded=1;fillColor=#1a1a2e;strokeColor=#333366;strokeWidth=3;" vertex="1" parent="1">
