        <mxCell id="p7-d3-4" value="&lt;b&gt;4. Productize Hermes as branded offering&lt;/b&gt;&lt;br/&gt;&quot;Hermes AI Employee&quot; — done-for-you setup package&lt;br/&gt;&lt;font style='font-size:7px;' color='#1e8449'&gt;Target: $1,500-$3,000 per install&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#eafaf1;strokeColor=#1e8449;strokeWidth=2;align=left;spacingLeft=8;" vertex="1" parent="1">
